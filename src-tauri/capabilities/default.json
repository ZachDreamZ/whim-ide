{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Whim's local main window. Filesystem, process, and deploy access are exposed only through validated Rust commands.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "opener:default",
    "dialog:allow-open",
    "updater:default"
  ]
}
